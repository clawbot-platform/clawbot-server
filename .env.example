# Copy this file to .env before running the foundation stack.
# Default/core stack:
# - PostgreSQL
# - Redis
# - NATS
#
# Optional stack (only when using deploy/compose/docker-compose.optional.yml):
# - MinIO
# - OmniRoute
# - ZeroClaw
# - Prometheus
# - Grafana
#
# Host bindings default to 127.0.0.1 so the stack stays local-only.
# Values marked REQUIRED_SECRET must be replaced by users when the related service is enabled.

COMPOSE_PROJECT_NAME=clawbot-foundation

# =========================================================
# Core services
# =========================================================

# PostgreSQL + pgvector
POSTGRES_IMAGE=pgvector/pgvector:pg16
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=clawbot
POSTGRES_USER=clawbot
POSTGRES_PASSWORD=REQUIRED_SECRET_replace_me_postgres

# Redis
REDIS_IMAGE=redis:7-alpine
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# NATS
NATS_IMAGE=nats:2.10-alpine
NATS_HOST=127.0.0.1
NATS_PORT=4222
NATS_MONITOR_PORT=8222

# =========================================================
# Local validation / app settings
# These are not required by the core compose file itself,
# but are useful for local runs, smoke checks, and when
# clawbot-server is started separately.
# =========================================================

STACK_SMOKE_TIMEOUT=5s

APP_ENV=development
SERVER_ADDRESS=127.0.0.1:8080
LOG_LEVEL=info
AUTO_MIGRATE=true
SHUTDOWN_TIMEOUT=10s
CLAWMEM_BASE_URL=
CLAWMEM_TIMEOUT=5s
CLAWBOT_IDENTITY_BASE_URL=
CLAWBOT_IDENTITY_TIMEOUT=5s
CLAWBOT_IDENTITY_TENANT=
INFERENCE_BASE_URL=http://ai-precision:11434
INFERENCE_TIMEOUT=120s
GUARDRAIL_TIMEOUT=30s
HELPER_TIMEOUT=30s
MODEL_PROVIDER=local_ollama
PRIMARY_MODEL=ibm/granite3.3:8b
GUARDRAIL_MODEL=ibm/granite3.3-guardian:8b
HELPER_MODEL=granite4:3b
LOCAL_OLLAMA_DISABLE_GUARDRAILS=false
ENABLE_COMPACT_DUAL_PAYLOAD=true
DEFAULT_EXECUTION_RING=ring_1
POLICY_BUNDLE_ID=ach-governance
POLICY_BUNDLE_VERSION=2026.1

# Use 127.0.0.1 when running clawbot-server locally on the host.
# If clawbot-server is later added to Compose as a container,
# switch the host portion to: postgres
DATABASE_URL=postgres://clawbot:REQUIRED_SECRET_replace_me_postgres@127.0.0.1:5432/clawbot?sslmode=disable

# Optional future/runtime URLs for local host-based runs
REDIS_URL=redis://127.0.0.1:6379
NATS_URL=nats://127.0.0.1:4222
CLAWBOT_NATS_URL=nats://127.0.0.1:4222

# =========================================================
# Optional services
# Only needed when using deploy/compose/docker-compose.optional.yml
# =========================================================

# MinIO
MINIO_IMAGE=minio/minio:latest
MINIO_HOST=127.0.0.1
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=REQUIRED_SECRET_replace_me_minio

# OmniRoute is the shared model gateway for optional runtime flows.
OMNIROUTE_IMAGE=diegosouzapw/omniroute:latest
OMNIROUTE_HOST=127.0.0.1
OMNIROUTE_PORT=20128
OMNIROUTE_BASE_URL=http://localhost:20128

# ZeroClaw is an optional runtime substrate that points at OmniRoute.
ZEROCLAW_VERSION=0.1.7
ZEROCLAW_HOST=127.0.0.1
ZEROCLAW_PORT=3000
ZEROCLAW_PROVIDER=openai
ZEROCLAW_API_URL=http://omniroute:20128/v1
ZEROCLAW_API_KEY=REQUIRED_SECRET_replace_me_omniroute_api_key
ZEROCLAW_DEFAULT_MODEL=if/kimi-k2-thinking
ZEROCLAW_GATEWAY_TOKEN=REQUIRED_SECRET_replace_me_zeroclaw_token
ZEROCLAW_RUST_LOG=info

# Prometheus
PROMETHEUS_IMAGE=prom/prometheus:latest
PROMETHEUS_HOST=127.0.0.1
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_IMAGE=grafana/grafana:latest
GRAFANA_HOST=127.0.0.1
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=REQUIRED_SECRET_replace_me_grafana


CLAWBOT_WATCHLIST_REVIEW_BASE_URL=http://127.0.0.1:8090
CLAWBOT_WATCHLIST_REVIEW_TIMEOUT=10s
